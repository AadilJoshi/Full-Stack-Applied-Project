generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  username String  @unique
  password String
  role     String  @default("user")

  orders   Order[]
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  description String
  price       Float
  category    String
  image       String
}

model Order {
  id        Int      @id @default(autoincrement())
  total     Float
  date      DateTime @default(now())

  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
}